# radar-dash configuration — copy to .env and fill in.
# Every value has a sensible default; nothing here is strictly required to boot,
# but you must point ADSB_HOST at a tar1090/readsb receiver to see any aircraft.

# ── ADS-B receiver (tar1090 / readsb / ultrafeeder) ──────────────────
ADSB_HOST=127.0.0.1          # IP/host of your receiver
ADSB_PORT=8080               # tar1090 web port
ADSB_STATION_LAT=            # your antenna latitude  (decimal degrees)
ADSB_STATION_LON=            # your antenna longitude (decimal degrees)
ADSB_STATION_ALT_FT=0        # antenna altitude in feet

# ── Server ───────────────────────────────────────────────────────────
RADAR_DASH_PORT=3010

# ── Branding (all optional; defaults are generic) ────────────────────
BRAND_NAME=radar             # the word shown in the header
BRAND_DOMAIN=                # e.g. example.com — empty shows just BRAND_NAME
PARENT_LINK_URL=             # optional "back" link in the header; empty hides it
PARENT_LINK_LABEL=← Home

# ── Home location / route filtering ──────────────────────────────────
HOME_LAT=                    # defaults to ADSB_STATION_LAT if unset
HOME_LON=
HOME_COUNTRY_ISO=US          # used for domestic/intl breakdowns
ROUTE_MAX_DETOUR_KM=450
ROUTE_MAX_CROSSTRACK_KM=500

# ── Admin (/admin/* — settings page) ─────────────────────────────────
# /admin fails CLOSED: with neither a token nor a trusted proxy header, it is denied.
# Set a token to allow access — reachable at /admin/settings?token=... (or the
# X-Admin-Token header), via either the host's IP or a domain.
ADMIN_TOKEN=
# Trust an authenticating proxy's identity header (Cloudflare Access sends
# cf-access-authenticated-user-email). OPT-IN, default false. ONLY set true when such
# a proxy actually fronts /admin and strips the header from outside requests —
# otherwise anyone can spoof it and bypass the token entirely.
ADMIN_TRUST_PROXY_HEADER=false
# Disable /admin auth entirely — for trusted LAN / localhost-only installs. OPT-IN,
# default false. NEVER set this on an internet-exposed host.
ADMIN_DISABLE_AUTH=false

# ── Feeder detection (optional) ──────────────────────────────────────
# The Feeders page detects which aggregators are running. Configure live at
# /admin/settings (mode: local | remote | off); these env vars only seed the
# defaults on first run.
#   local  — inspect the Docker daemon on THIS box (dashboard + feeders co-located)
#   remote — `docker inspect` over SSH on the receiver (set ADSB_SSH_HOST below)
#   off    — no detection; feeders taken from FEEDER_ENABLED_KEYS
# If ADSB_SSH_HOST is set, mode defaults to "remote"; otherwise "off".
ADSB_SSH_HOST=
ADSB_SSH_USER=root
# ADSB_SSH_KEY=~/.ssh/id_ed25519
# Optional override — comma-separated feeder keys to force "installed" when they
# can't be auto-detected (e.g. "off" mode, or an aggregator we can't probe).
# Ultrafeeder aggregators + container feeders are auto-detected, so usually blank.
FEEDER_ENABLED_KEYS=
# Master key (base64 of 32 random bytes) that encrypts a stored SSH password, if
# you choose password auth at /admin/settings. Leave blank to auto-generate
# data/.master.key on first use. Generate: `openssl rand -base64 32`
RADAR_SECRET_KEY=

# ── External data sources (optional) ─────────────────────────────────
OPENSKY_USER=                # raises OpenSky rate limit (anon ≈ 40/day)
OPENSKY_PASS=
ROUTESET_URL=https://adsb.im/api/0/routeset
ADSBX_TRACE_URL=             # override ADSBExchange globe trace host
PLANE_ALERT_CSV_URL=         # override plane-alert-db watchlist source
FAR_VERIFY_BUDGET=4          # max OpenSky far-route verifications per cycle
INTERESTING_POLL_MS=10000    # watchlist poll cadence
PATHS_SCOPE=overhead         # overhead | all

# ── PWA / direct HTTPS (optional) ────────────────────────────────────
# The dashboard is an installable PWA, but browsers only enable install +
# offline from a SECURE CONTEXT (HTTPS, or http://localhost). With no domain
# you have three easy options — see the "PWA / installing the app" section of
# the README. To serve TLS straight from the container, mount a cert your
# devices TRUST (mkcert / Let's Encrypt / `tailscale cert`) and set:
# HTTPS_CERT=/app/certs/cert.pem
# HTTPS_KEY=/app/certs/key.pem
# HTTPS_PORT=3443
# (The plain HTTP port keeps working; HTTPS is added alongside it.)

# ── Update check (Docker) ────────────────────────────────────────────
# When running in a container the header shows an "↑ Update" badge if a newer
# version has been published. Best-effort, cached, read-only — never auto-updates.
# UPDATE_CHECK_ENABLED=false                  # disable the check entirely
# UPDATE_CHECK_URL=https://raw.githubusercontent.com/<you>/<repo>/main/package.json
# UPDATE_DOC_URL=https://github.com/<you>/<repo>/blob/main/UPDATING.md
# UPDATE_CHECK_INTERVAL_HOURS=12
# RADAR_IN_DOCKER=true                        # force "in container" (auto-set in the image)

# ── Advanced ─────────────────────────────────────────────────────────
# SECRETS_PATH=/path/to/shared.env   # extra env file merged on top of .env
